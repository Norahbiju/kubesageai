# KubeSage AI production runtime configuration.
# Copy to .env on the VM and replace every value before starting Compose.

POSTGRES_DB=kubesage
POSTGRES_USER=kubesage
POSTGRES_PASSWORD=kubesage
DATABASE_URL=postgresql+asyncpg://kubesage:kubesage@postgres:5432/kubesage

REDIS_URL=redis://redis:6379/0

FRONTEND_URL=https://kubesage.nexaflow.site
BACKEND_URL=https://kubesage.nexaflow.site
NEXT_PUBLIC_API_URL=https://kubesage.nexaflow.site
CORS_ORIGINS=["https://kubesage.nexaflow.site"]

AZURE_TENANT_ID=e273e7a6-0676-4113-8575-ca2b6f3dd2ad
AZURE_CLIENT_ID=a6ae8259-84e5-41c3-9508-ef065a12f123
# Do not commit a real client secret. Put the real value only in the VM's untracked .env file.
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=https://kubesage.nexaflow.site/auth/callback

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_ALGORITHM=HS256
SESSION_COOKIE_NAME=kubesage_session
ENCRYPTION_KEY=

LOG_LEVEL=INFO

DOMAIN=kubesage.nexaflow.site
ACME_EMAIL=norahelizabethbiju15@gmail.com
