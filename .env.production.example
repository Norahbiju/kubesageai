# KubeSage AI production runtime configuration.
# Copy to .env on the VM and replace every example value.

DEMO_MODE=false

# A real DNS name is required for trusted HTTPS and Microsoft Entra production login.
DOMAIN=kubesage.example.com
ACME_EMAIL=admin@example.com

FRONTEND_URL=https://kubesage.example.com
BACKEND_URL=https://kubesage.example.com
NEXT_PUBLIC_API_URL=same-origin
CORS_ORIGINS=["https://kubesage.example.com"]
AZURE_REDIRECT_URI=https://kubesage.example.com/api/auth/azure/callback

AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

JWT_SECRET=replace-with-at-least-32-random-bytes
NEXTAUTH_SECRET=replace-with-at-least-32-random-bytes
