# Shared
APP_ENV=local
APP_NAME=AKS Governance Platform
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Backend
POSTGRES_DB=aks_governance
POSTGRES_USER=aks_governance
POSTGRES_PASSWORD=aks_governance
DATABASE_URL=postgresql+psycopg://aks_governance:aks_governance@localhost:5432/aks_governance
REDIS_URL=redis://localhost:6379/0
BACKEND_CORS_ORIGINS=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]
SESSION_SECRET=replace-with-32-byte-random-secret
JWT_SECRET=replace-with-32-byte-random-secret
JWT_ALGORITHM=HS256
SESSION_COOKIE_NAME=kubesage_session
DEMO_MODE=true
AUTO_CREATE_SCHEMA=false
LOG_LEVEL=INFO

# Local demo encryption key. Replace outside local testing.
ENCRYPTION_KEY=G4Qlm8Kv63mDhZQPHVvzs5SnHYGHU_db1WULeJq5YLI=

# Microsoft Entra ID
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:8000/auth/callback
AZURE_AUTHORITY=https://login.microsoftonline.com/00000000-0000-0000-0000-000000000000/v2.0
AZURE_API_AUDIENCE=api://00000000-0000-0000-0000-000000000000
AZURE_ALLOWED_TENANTS=00000000-0000-0000-0000-000000000000
AZURE_OPERATION_AUTH_MODE=default_credential
AZURE_SUBSCRIPTION_IDS=

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
NEXT_PUBLIC_AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
NEXT_PUBLIC_AZURE_API_SCOPE=api://00000000-0000-0000-0000-000000000000/access_as_user
NEXT_PUBLIC_AZURE_REDIRECT_URI=http://localhost:3000/auth/callback
NEXT_PUBLIC_DEMO_MODE=true
