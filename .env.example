APP_ENV=local
LOG_LEVEL=INFO

POSTGRES_DB=kubesage
POSTGRES_USER=kubesage
POSTGRES_PASSWORD=kubesage
DATABASE_URL=postgresql+asyncpg://kubesage:kubesage@postgres:5432/kubesage
REDIS_URL=redis://redis:6379/0

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:3000"]

AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=organizations
AZURE_AUTHORITY=https://login.microsoftonline.com/organizations
AZURE_REDIRECT_URI=http://localhost:8000/api/auth/callback
AZURE_SCOPES=openid profile email offline_access https://management.azure.com/user_impersonation

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_ALGORITHM=HS256
SESSION_COOKIE_NAME=kubesage_session
ENCRYPTION_KEY=
