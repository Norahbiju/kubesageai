# KubeSage AI local/VM runtime configuration.
# Copy to .env on the VM and edit values:
# cp .env.example .env

# For demo bypass, use true. For real Microsoft Entra ID, use false.
DEMO_MODE=false
PUBLIC_PORT=80

# Public URLs used by browser and OAuth redirects.
# With the included Nginx reverse proxy, browser traffic uses one public origin.
FRONTEND_URL=http://localhost
BACKEND_URL=http://localhost
NEXT_PUBLIC_API_URL=same-origin
CORS_ORIGINS=["http://localhost"]
AZURE_REDIRECT_URI=http://localhost/api/auth/azure/callback

# Real Microsoft Entra ID app registration values.
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
AZURE_SUBSCRIPTION_IDS=[]

# Optional. If absent, the app uses deterministic MVP analysis.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Change this before exposing the app.
JWT_SECRET=replace-with-a-long-random-string
NEXTAUTH_SECRET=replace-with-a-long-random-string
