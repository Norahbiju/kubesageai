POSTGRES_DB=kubesage
POSTGRES_USER=kubesage
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://kubesage:change-me@postgres:5432/kubesage

REDIS_URL=redis://redis:6379/0

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:3000","https://kubesage.nexaflow.site"]

AZURE_TENANT_ID=e273e7a6-0676-4113-8575-ca2b6f3dd2ad
AZURE_CLIENT_ID=a6ae8259-84e5-41c3-9508-ef065a12f123
# Do not commit a real client secret. Put the real value only in your untracked .env file.
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=http://localhost:8000/auth/callback

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

JWT_SECRET=replace-with-32-plus-random-bytes
JWT_ALGORITHM=HS256
SESSION_COOKIE_NAME=kubesage_session

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

LOG_LEVEL=INFO
